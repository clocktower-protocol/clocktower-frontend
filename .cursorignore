# --- Secrets (hard block; do not rely on .gitignore alone) ---
.env
.env.*
!.env.example

# --- Dependencies & VCS ---
node_modules/
.pnp
.pnp.js
.git/

# --- Build & test outputs ---
build/
dist/
coverage/
.nyc_output/

# --- Playwright ---
test-results/
playwright-report/
playwright/.cache/

# --- Cloudflare local state ---
.wrangler/
.wrangler.toml

# --- Lockfiles & logs ---
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- IDE / OS noise ---
.vscode/
.vscode-test/
.idea/
.DS_Store
.VSCodeCounter/
*.vsix
